# === 必須 ===
OPENAI_API_KEY=sk-...

# === OpenAI API 設定 ===
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SEC=90

# === モデルルーティング ===
# 既定モデル（未指定時のフォールバック）
# ここで設定する値はアプリ起動時の初期値です。
# Streamlit画面でモデルを選択した場合は、その選択値が実行時に優先されます。
OPENAI_MODEL=gpt-5-nano

# 抽出: 議事録 / RFP -> 構造化 JSON
OPENAI_EXTRACT_MODEL=gpt-5-nano

# 生成: 提案資料 / 質問 / 説明文
OPENAI_GENERATE_MODEL=gpt-5-mini

# 批評: 整合チェック用
OPENAI_CRITIQUE_MODEL=gpt-5-nano

# 判断中枢（Planner）: 次アクション判断・再評価用
OPENAI_PLANNER_MODEL=gpt-5-mini

# 復旧: 将来の再計画用
OPENAI_RECOVER_MODEL=gpt-5-mini

# === アプリ設定 ===
LOG_LEVEL=INFO
ARTIFACTS_DIR=artifacts
KNOWLEDGE_DIR=knowledge
TEMPLATES_DIR=templates
LOGS_DIR=logs

# === 将来拡張用 ===
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# OTHER_API_ENDPOINT=https://...
# VECTOR_DB_URL=...
